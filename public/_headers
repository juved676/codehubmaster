/*
  # Default security headers
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin

/*.html
  # Don't cache HTML files - ensures fresh content for search engines
  Cache-Control: public, max-age=0, must-revalidate
  X-Content-Type-Options: nosniff

/index.html
  # Main app entry - never cache for SEO freshness
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# Static assets with content hashing - cache for 1 year (immutable)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# All CSS files - aggressive caching
/*.css
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: text/css; charset=utf-8

# All JavaScript files - aggressive caching
/*.js
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: application/javascript; charset=utf-8

# JS files in subdirectories
/assets/*.js
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: application/javascript; charset=utf-8

# CSS files in subdirectories  
/assets/*.css
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: text/css; charset=utf-8

# All image formats - long cache with immutable
/*.jpg
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: image/jpeg

/*.jpeg
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: image/jpeg

/*.png
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: image/png

/*.webp
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: image/webp

/*.avif
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: image/avif

/*.svg
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: image/svg+xml

/*.gif
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: image/gif

# Hero image - prioritized caching
/hero-bg.webp
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: image/webp

# All fonts - long cache
/*.woff2
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: font/woff2
  Access-Control-Allow-Origin: *

/*.woff
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: font/woff
  Access-Control-Allow-Origin: *

/*.ttf
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: font/ttf
  Access-Control-Allow-Origin: *

/*.otf
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: font/otf
  Access-Control-Allow-Origin: *

# SEO files - moderate cache
/sitemap.xml
  Content-Type: application/xml; charset=utf-8
  Cache-Control: public, max-age=3600

/sitemap-ai.xml
  Content-Type: application/xml; charset=utf-8
  Cache-Control: public, max-age=3600

/robots.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=3600

/ads.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=86400
  Access-Control-Allow-Origin: *

/ai-capabilities.json
  Content-Type: application/json; charset=utf-8
  Cache-Control: public, max-age=3600

# Favicon - long cache
/favicon.png
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: image/png

/favicon.ico
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: image/x-icon

# Service worker - never cache
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
  Content-Type: application/javascript; charset=utf-8
